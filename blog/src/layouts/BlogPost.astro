---
import '../styles/global.css'

interface Props {
  title: string
  pubDate: Date
  description?: string
  canonicalPath: string
}

const { title, pubDate, description, canonicalPath } = Astro.props
const canonical = new URL(canonicalPath, `${Astro.site}/`).href
const home = import.meta.env.BASE_URL.replace(/\/+$/, '') || '/'
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
  </head>
  <body>
    <a class="back" href={home}>← All posts</a>
    <article>
      <header>
        <h1>{title}</h1>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </body>
</html>
