---
import BaseLayout from './BaseLayout.astro'

interface Props {
  title: string
  pubDate: Date
  description?: string
  canonicalPath: string
}

const { title, pubDate, description, canonicalPath } = Astro.props
const home = import.meta.env.BASE_URL.replace(/\/+$/, '') || '/'
const metaDescription = description?.trim() || undefined
---

<BaseLayout
  title={title}
  description={metaDescription}
  canonicalPath={canonicalPath}
  mainClass="page-main page-main--post"
  bodyClass="site-body--post"
>
  <div class="post-panel">
    <a class="back" href={home}>← All posts</a>
    <article>
      <header>
        <h1>{title}</h1>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>
