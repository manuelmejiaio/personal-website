---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)
---

<BaseLayout
  title="Manuel's Blog"
  description="Software, web, and notes — Manuel Mejia."
  canonicalPath="/blog"
  bodyClass="site-body--post"
  mainClass="page-main page-main--post"
>
  <div class="post-panel blog-index">
    <h1 class="blog-index__title">Blog ✍</h1>
    <div class="blog-index__list">
      <ul class="blog-index__posts">
        {
          posts.map((post) => (
            <li>
              <a href={post.data.canonicalPath}>
                <span class="blog-index__post-title">{post.data.title}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <a class="blog-index__more" href="/">← Back to home</a>
  </div>
</BaseLayout>
